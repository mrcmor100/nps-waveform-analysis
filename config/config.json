{
  "processing_settings": {
    "waveform_analysis_version": "1.0.0",
    "num_cores": 8
  },
  "io_settings": {
    "base_path": "./",
    "input_subdir": "replays/",
    "output_subdir": "output/",
    "input_rootfile": "nps_hms_coin_%d_%d_1_-1.root",
    "input_tree": "T",
    "input_segments": [0, 3],
    "output_tree": "TOUT",
    "output_rootfile": "nps_hms_coin_%d_%d_1_-1_out.root"
  },

  "global": {
    "nchannel": 16, 
    "nblocks": 1080,
    "ncol": 30, 
    "nlin": 36, 
    "maxpulses": 4, 
    "maxwfpulses": 12, 
    "ntemp": 56, 
    "ntime": 110, 
    "nfADC": 7, 
    "dt": 4.0, 
    "nslots": 1104, 
    "ADCtomV": 0.244140625, 
    "integtopC": 0.020,
    "timerefacc": 0.0
  }, 

  "run_parameters": [
    {
      "range": [55, 56], 
      "ntime": 100
    }, 
    { 
      "range": [2016, 2016], 
      "timerefacc": -10
    }
  ], 

  "tdc_files": {
    "patterns": [
      { "range": [6000, 7500], "path": "tdc_offsets/tdc_6000-7500.txt" },
      { "range": [5183, 5208], "path": "tdc_offsets/tdc_5183-5208.txt" }
    ],
    "default_pattern": "tdc_offsets/default_tdc.txt"
  },

  "waveform_files": {
    "patterns": [
      { "range": [6183, 7500], "path": "reference_waveforms/6171-6183/ref_wf_%d.txt" }, 
      { "range": [5236, 6151], "path": "reference_waveforms/5217-5236/ref_wf_%d.txt" }
    ],
    "default_pattern": "reference_waveforms/default/ref_wf_%d.txt"
  },

  "branches": [
  ],
  "cuts": [
    {"name": "theta", "variable": "th", "value": "internal_var > th", "section": 1},
    {"name": "phi", "variable": "ph", "value": "", "section": 1},
    {"name": "delta", "variable": "dp", "value": "", "section": 1},
    {"name": "HMS_corr_time", "variable": "", "value": "", "section": 2},
    {"name": "Samptime", "variable": "", "value": "", "section": 2}
  ]
}
