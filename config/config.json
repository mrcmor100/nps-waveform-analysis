{
  //Make everything based on the project root directory, not global for modularity
  "project_settings": {
    "base_path": "./", //Where the data goes, or move to top dir for drop-in from swif2
    "waveform_subdir": "waveforms/", // Where the reference waveform text files go
    "tdc_subdir": "tdc_offsets/", // A directory for a single file, but more could be added as needed
    "replays_subdir": "replays/",
    "output_subdir": "output/",
    "num_cores": 8
  },
  "global": {
    // Calorimeter global parameters
    "nchannel": 16, // Number of fADC channels in each fADC card
    "ncol": 30, // Calorimeter specific number of columns
    "nlin": 36, // Calorimeter specific number of rows

    // Fitting parameters
    "maxpulses": 4, //TODO - Move out to fitting abstraction
    "maxwfpulses": 12, //TODO - Move out to fitting abstraction

    // Temperature parameters and function.
    "ntemp": 56, // Incorporate Temperature module / class

    // All of these are ADC specific parameters - set to specific ADCs?
    "ntime": 110, // ntime is an adc parameter, but needed in fitting.
    "nfADC": 7,
    "dt": 4.0,
    "nslots": 1104,
    "ADCtomV": 0.244140625,
    "integtopC": 0.020
  },
  //Overrides of global settings like for run 55-56, ntime is 100 instead of 110
  //run_patameters[param]
  // param["range"][0]
  //  Global overrides if param[<name>] is not range.
  "run_parameters": [
    {
      // Override global ntime for runs 55 - 56 to ntime=100
      "range": [55, 56],
      "ntime": 100
    },
    {
      // Override global timerefacc to -10 for run 2016
      "range": [2016, 2016],
      "timerefacc": -10
    }
  ],
  "filename_patterns": {
    "input_rootfile": "nps_hms_coin_%d_%d_1_-1.root",
    "output_rootfile": "nps_hms_coin_%d_%d_1_-1_out.root",
    "tdc_offsets": "tdc_offset_param.txt"

  },
  "waveform_files": [
    { "range": [6183, 7500], "path": "6171-6183/ref_wf_%d.txt" },
    { "range": [5236, 6151], "path": "5217-5236/ref_wf_%d.txt" }
  ],
  "branches": [
    { "name": "NPS.cal.fly.adcSampWaveform", "type": "Double_t", "is_array": true, "variable": "sampWaveform" },
    { "name": "NPS.cal.fly.adcCounter", "type": "Double_t", "is_array": true, "variable": "adcCounter" },
    { "name": "T.hms.hT1_tdcTime", "type": "Double_t", "variable": "hT1_time" },
    { "name": "H.react.x", "type": "Double_t", "variable": "vx" }
  ]
}
